# Database (PostgreSQL, falls back to SQLite if not set)
DATABASE_URL=postgres://user:password@host:port/dbname
# POSTGRES_URL=postgres://... (also supported as fallback)

# Auth
JWT_SECRET=your-secret-change-me
JWT_EXPIRY=24h

# Server
PORT=3000

# Books path for serverless environments
# BOOKS_PATH=/tmp/books
